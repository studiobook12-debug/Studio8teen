# Supabase — copy to .env.local
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy name also supported: VITE_SUPABASE_ANON_KEY

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=studiobook_uploads

# OpenRouter — for AI image analysis (get key at openrouter.ai/keys)
# Add the SAME key you used for: supabase secrets set OPENROUTER_API_KEY=...
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here
